<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоСписано</dataPath>
			<field>КоличествоСписано</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество списано</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Фирма</dataPath>
			<field>Фирма</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВидПродукции</dataPath>
			<field>ВидПродукции</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоПродано</dataPath>
			<field>КоличествоПродано</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество продано</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МоделиПродукции</dataPath>
			<field>МоделиПродукции</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Год</dataPath>
			<field>Год</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Год</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:periodNumber>1</dcscom:periodNumber>
				<dcscom:periodType>Main</dcscom:periodType>
			</role>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Продажи.Фирма КАК Фирма,
	Продажи.ВидПродукции КАК ВидПродукции,
	Продажи.МоделиПродукции КАК МоделиПродукции,
	ГОД(Продажи.Период) КАК Год,
	СУММА(Продажи.Количество) КАК КоличествоПродано
ПОМЕСТИТЬ ВТ_Продажи
ИЗ
	РегистрНакопления.Продажи КАК Продажи
ГДЕ
	Продажи.Период МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
СГРУППИРОВАТЬ ПО
	Продажи.Фирма,
	Продажи.ВидПродукции,
	Продажи.МоделиПродукции,
	ГОД(Продажи.Период)

ИНДЕКСИРОВАТЬ ПО
	МоделиПродукции,
	Год
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Акты.МодельПродукции КАК МодельПродукции,
	ГОД(Акты.Период) КАК Год,
	СУММА(Акты.Количество) КАК КоличествоСписано
ПОМЕСТИТЬ ВТ_Списания
ИЗ
	РегистрНакопления.АктыПродукцияИКод КАК Акты
ГДЕ
	Акты.Период МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
СГРУППИРОВАТЬ ПО
	Акты.МодельПродукции,
	ГОД(Акты.Период)

ИНДЕКСИРОВАТЬ ПО
	МодельПродукции,
	Год
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Продажи.Фирма КАК Фирма,
	ВТ_Продажи.ВидПродукции КАК ВидПродукции,
	ВТ_Продажи.МоделиПродукции КАК МоделиПродукции,
	ВТ_Продажи.Год КАК Год,
	ВТ_Продажи.КоличествоПродано КАК КоличествоПродано,
	ВТ_Списания.КоличествоСписано КАК КоличествоСписано
ИЗ
	ВТ_Продажи КАК ВТ_Продажи
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Списания КАК ВТ_Списания
		ПО ВТ_Продажи.МоделиПродукции = ВТ_Списания.МодельПродукции
		И ВТ_Продажи.Год = ВТ_Списания.Год</query>
	</dataSet>
	<calculatedField>
		<dataPath>ПроцентСписанных</dataPath>
		<expression/>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Процентное соотношение</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>ПроцентСписанных</dataPath>
		<expression>Окр(ЕСТЬNULL(Сумма(КоличествоСписано) / Сумма(КоличествоПродано) * 100, 0), 2)</expression>
	</totalField>
	<totalField>
		<dataPath>КоличествоСписано</dataPath>
		<expression>Сумма(КоличествоСписано)</expression>
	</totalField>
	<totalField>
		<dataPath>КоличествоПродано</dataPath>
		<expression>Сумма(КоличествоПродано)</expression>
	</totalField>
	<parameter>
		<name>ПериодОтчета</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период отчета</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>v8:StandardPeriod</v8:Type>
		</valueType>
		<value xsi:type="v8:StandardPeriod">
			<v8:variant xsi:type="v8:StandardPeriodVariant">Custom</v8:variant>
			<v8:startDate>0001-01-01T00:00:00</v8:startDate>
			<v8:endDate>0001-01-01T00:00:00</v8:endDate>
		</value>
		<useRestriction>false</useRestriction>
	</parameter>
	<parameter>
		<name>ДатаНачала</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата начала</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>&amp;ПериодОтчета.ДатаНачала</expression>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>ДатаОкончания</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата окончания</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>&amp;ПериодОтчета.ДатаОкончания</expression>
		<availableAsField>false</availableAsField>
	</parameter>
